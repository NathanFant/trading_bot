{
  "builds": [
    { "src": "package.json",   "use": "@vercel/static-build", "config": { "distDir": "dist" } },
    { "src": "api/cycle.py",   "use": "@vercel/python" },
    { "src": "api/status.py",  "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/cycle",  "dest": "/api/cycle.py"  },
    { "src": "/api/status", "dest": "/api/status.py" }
  ]
}
