# Robinhood Crypto API — get key ID from https://robinhood.com/crypto/developer
ROBINHOOD_API_KEY=rh-api-xxxx
ROBINHOOD_PRIVATE_KEY=<base64-encoded Ed25519 private key from public_key.py>

# Optional: CoinMarketCap API key for FGI (free tier works)
COINMARKETCAP_API_KEY=

# Discord webhook URL for trade alerts (optional)
DISCORD_WEBHOOK_URL=

# Vercel KV (Upstash Redis) — injected automatically when you add KV in Vercel dashboard
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Cron protection — any random string, set same value in Vercel env vars
CRON_SECRET=

# Trading config
SYMBOL=SOL-USD
DRY_RUN=true                  # set false for live trading
SCALE_BUY_WITH_Z=true         # ramp buy size with fear intensity (recommended)
MIN_BUY_PCT=0.24              # buy fraction at threshold z-score
MAX_BUY_PCT=0.74              # buy fraction at peak fear
MAX_SCALE_Z=4.0               # z-score where MAX_BUY_PCT is reached
SELL_PCT=0.65                 # fraction of holdings to sell per signal
MIN_CONFIDENCE=0.53           # minimum signal confidence to execute
BUY_Z_THRESHOLD=-1.95         # z-score below this triggers buy
SELL_Z_THRESHOLD=2.65         # z-score above this triggers sell
POLL_INTERVAL_SECONDS=3600    # how often to check (1 hour default)
FGI_HISTORY_DAYS=55           # lookback window for z-score baseline
